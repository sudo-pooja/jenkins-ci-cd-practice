pipeline {
    agent any
    environment {
        IMAGE = "cicd-project:${env.BUILD_NUMBER ?: 'latest'}"
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                script {
                    if (isUnix()) {
                        sh "docker build -t ${IMAGE} ."
                    } else {
                        bat "docker build -t %IMAGE% ."
                    }
                }
            }
        }
        stage('Run') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'docker volume create cicd-data || true'
                        sh 'docker rm -f cicd-project || true'
                        sh "docker run -d -p 9090:3000 --name cicd-project -v cicd-data:/usr/src/app/data ${IMAGE}"
                    } else {
                        bat 'docker volume create cicd-data || echo ignore'
                        bat 'docker rm -f cicd-project || echo ignore'
                        bat "docker run -d -p 9090:3000 --name cicd-project -v cicd-data:/usr/src/app/data %IMAGE%"
                    }
                }
            }
        }
    }
    post {
        success { echo 'App running at http://<HOST_IP>:9090' }
        failure { echo 'Pipeline failed!' }
    }
}